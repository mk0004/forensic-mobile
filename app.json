{
  "expo": {
    "name": "forensic",
    "slug": "forensic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/forensic-logo.png",
    "scheme": "forensic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mokhaled2072.forensic",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B2C5E",
        "foregroundImage": "./assets/images/forensic-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mokhaled2072.forensic"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/forensic-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/forensic-logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#1B2C5E",
          "dark": {
            "backgroundColor": "#1B2C5E"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4609920e-3d01-4443-a110-971dcdbb19f3"
      }
    },
    "owner": "mokhaled2072",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4609920e-3d01-4443-a110-971dcdbb19f3"
    }
  }
}
